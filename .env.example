# Local ZKTeco portal database
DATABASE_URL=mysql://user:password@127.0.0.1:3306/zkteco_portal

# ZKTeco device connection
ZK_DEFAULT_PORT=4370
ZK_TIMEOUT_MS=10000
ZK_INPORT=4000
LIVE_SYNC_INTERVAL_MS=30000

# Easyvate VPS ingestion endpoint
VMS_API_URL=https://niazikhpalwak.com/admin/api/attendance/device-sync
VMS_API_KEY=replace-with-the-value-used-by-Easyvate-ZK_SYNC_API_KEY
